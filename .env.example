# Firebase Realtime Database config.
# Create a Firebase web app, then copy these values from Project settings.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Production default: keep demo mode off so missing Firebase is caught immediately.
# Set to true only for local layout testing before the meeting.
VITE_ENABLE_DEMO_MODE=false

# Basic classroom-only protection for /#/admin.
# This is visible in the built static files, so do not use a sensitive password.
VITE_ADMIN_PASSWORD=change-this-classroom-password

# Optional. The default "./" works for GitHub Pages project sites.
# Use "/your-repository-name/" only if you prefer absolute asset paths.
# VITE_BASE_PATH=/your-repository-name/
